#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# underscore — thin CLI wrapper
#
# Host-side glue around `docker run`. The wrapper owns the operations that
# can't move into the container:
#
#   • Volume mount     — `-v <path>:/repo` when the input is a local path.
#   • Port publish     — `-p <port>:<port>`, peeked from --port in the args.
#   • Container name   — so `underscore stop` can find and remove a container.
#   • Lifecycle verbs  — stop, update (re-run installer), version (wrapper).
#
# Per-subcommand flag semantics live in the image. The wrapper never owns
# `--port`; it observes the value for `-p` and forwards the flag verbatim.
# Top-level `--help` is wrapper-owned (instant, doesn't require a running
# runtime); `underscore <subcommand> --help` is forwarded to the image.
# ---------------------------------------------------------------------------

UNDERSCORE_VERSION="0.1.3"
UNDERSCORE_IMAGE="${UNDERSCORE_IMAGE:-ghcr.io/logphase/underscore-cli:${UNDERSCORE_VERSION}}"
UNDERSCORE_INSTALLER_URL="${UNDERSCORE_INSTALLER_URL:-https://raw.githubusercontent.com/logphase/underscore-cli-installer/main/install.sh}"

DEFAULT_PORT=9000

if command -v podman >/dev/null 2>&1; then
    RUNTIME="podman"
elif command -v docker >/dev/null 2>&1; then
    RUNTIME="docker"
else
    RUNTIME=""
fi

die() { echo "Error: $*" >&2; exit 1; }

ensure_docker() {
    [[ -n "$RUNTIME" ]] || die "Docker or Podman is required but neither is installed.
  Install Docker: https://docs.docker.com/get-docker/
  Install Podman: https://podman.io/getting-started/installation"
    "$RUNTIME" info >/dev/null 2>&1 || die "${RUNTIME} is installed but not running. Start it and try again."
}

container_name() { echo "underscore-viz-$1"; }

stop_viz() {
    local name; name="$(container_name "$1")"
    if "$RUNTIME" ps -q --filter "name=${name}" 2>/dev/null | grep -q .; then
        "$RUNTIME" stop "${name}" >/dev/null 2>&1 || true
        "$RUNTIME" rm "${name}" >/dev/null 2>&1 || true
    fi
}

stop_all_viz() {
    local ids
    ids=$("$RUNTIME" ps -q --filter "name=underscore-viz-" 2>/dev/null || true)
    [[ -z "$ids" ]] && return 0
    # shellcheck disable=SC2086
    "$RUNTIME" stop $ids >/dev/null 2>&1 || true
    # shellcheck disable=SC2086
    "$RUNTIME" rm   $ids >/dev/null 2>&1 || true
}

resolve_path() {
    local input="$1"
    if [[ -d "$input" ]]; then
        cd "$input" && pwd
    elif [[ -f "$input" ]]; then
        cd "$(dirname "$input")" && echo "$(pwd)/$(basename "$input")"
    else
        echo "$input"
    fi
}

is_url() {
    [[ "$1" =~ ^https?:// ]] || [[ "$1" =~ ^git@ ]]
}

# Peek at --port in the args without consuming it. The container also sees
# the flag and is the source of truth for its meaning; we just need the
# value for the host:container port mapping.
extract_port() {
    local port="$DEFAULT_PORT"
    local next_is_port=false
    for arg in "$@"; do
        if $next_is_port; then port="$arg"; next_is_port=false; continue; fi
        case "$arg" in
            --port=*) port="${arg#--port=}" ;;
            --port)   next_is_port=true ;;
        esac
    done
    echo "$port"
}

# Volume mount + port publish + opaque forward. The first positional must
# be the input (URL or path); everything else is passed to the container
# untouched, including --port.
run_with_input() {
    local subcommand="$1"; shift

    if [[ $# -eq 0 ]] || [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
        exec "$RUNTIME" run --rm --init "${UNDERSCORE_IMAGE}" "$subcommand" --help
    fi

    local input="$1"; shift
    local port; port=$(extract_port "$@")

    local docker_args=()
    local container_input

    if is_url "$input"; then
        container_input="$input"
    else
        local abs_path
        abs_path="$(resolve_path "$input")"
        [[ -d "$abs_path" ]] || die "Local path not found: $input (resolved to: $abs_path)
  Tip: the input must be the first argument, before any flags."
        docker_args+=(-v "${abs_path}:/repo")
        container_input="/repo"
    fi

    stop_viz "$port"

    # --init runs tini as PID 1 inside the container. After the entrypoint
    # `exec`s into busybox httpd, busybox becomes PID 1 — and signals from
    # `docker run` (without -t) don't propagate cleanly to a non-init PID 1,
    # so Ctrl+C would hang. tini fixes that.
    exec "$RUNTIME" run --rm --init \
        --name "$(container_name "$port")" \
        -p "${port}:${port}" \
        ${docker_args[@]+"${docker_args[@]}"} \
        "${UNDERSCORE_IMAGE}" \
        "$subcommand" "$container_input" "$@"
}

# `stop` is wrapper-only — it manipulates host containers, not the image —
# so it owns its own --port flag without duplicating image behavior.
cmd_stop() {
    local stop_all=false
    local port="$DEFAULT_PORT"
    local next_is_port=false
    for arg in "$@"; do
        if $next_is_port; then port="$arg"; next_is_port=false; continue; fi
        case "$arg" in
            --all)    stop_all=true ;;
            --port=*) port="${arg#--port=}" ;;
            --port)   next_is_port=true ;;
        esac
    done

    if $stop_all; then
        stop_all_viz
        echo "  Stopped all underscore visualization containers."
    else
        stop_viz "$port"
        echo "  Stopped port ${port}."
    fi
}

print_usage() {
    cat <<EOF
underscore — understand a C# or Java codebase in one command

Usage:
  underscore analyze <repo-url-or-path>     Analyze a codebase and open the
                                            visualization in your browser.

  underscore pr <repo-path>                 Compare two commits and highlight
                                            which journeys the change touches.

  underscore stop [--all]                   Stop the running visualization.
                                            --all stops every underscore
                                            container on the host.

  underscore update                         Update underscore to the latest
                                            version.

  underscore version                        Show the installed version.

Examples:
  underscore analyze https://github.com/dotnet/aspnetcore
  underscore analyze ./my-project
  underscore pr ./my-repo --base main
  underscore analyze ./my-project --port 9001

Run multiple analyses at the same time by giving each a different port:
  underscore analyze ./repo-a --port 9000
  underscore analyze ./repo-b --port 9001

For the full list of options on analyze or pr:
  underscore analyze --help
  underscore pr --help
EOF
}

cmd_update() {
    # The wrapper pins ${UNDERSCORE_IMAGE} to its own version, so a plain
    # `podman pull` would not move the user forward. Re-running the installer
    # fetches a newer wrapper, which in turn pins (and pulls) the matching
    # newer image — wrapper and image upgrade together.
    echo "  Re-running installer to upgrade underscore..."
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "${UNDERSCORE_INSTALLER_URL}" | bash
    elif command -v wget >/dev/null 2>&1; then
        wget -qO- "${UNDERSCORE_INSTALLER_URL}" | bash
    else
        die "curl or wget is required to update"
    fi
}

command="${1:-}"
shift 2>/dev/null || true

# Wrapper-owned commands that don't need the runtime running.
case "$command" in
    version)            echo "underscore ${UNDERSCORE_VERSION}"; exit 0 ;;
    --help|-h|help|"")  print_usage; exit 0 ;;
esac

ensure_docker

case "$command" in
    analyze|pr)  run_with_input "$command" "$@" ;;
    pr-analyze)  run_with_input pr "$@" ;;          # legacy alias
    stop)        cmd_stop "$@" ;;
    update)      cmd_update ;;
    *)
        echo "Error: unknown command '${command}'" >&2
        echo >&2
        print_usage >&2
        exit 2
        ;;
esac
